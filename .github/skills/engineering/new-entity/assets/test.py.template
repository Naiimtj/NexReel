def test_create_{entity}(client):
    response = client.post(
        "/{entities}/",
        json={{"name": "Test {Entity}"}},
    )
    assert response.status_code == 201
    data = response.json()
    assert data["name"] == "Test {Entity}"
    assert "{entity}_id" in data


def test_list_{entities}(client):
    response = client.get("/{entities}/")
    assert response.status_code == 200
    assert isinstance(response.json(), list)


def test_get_{entity}(client):
    # Create one first
    create = client.post("/{entities}/", json={{"name": "Get Test"}})
    item_id = create.json()["{entity}_id"]

    response = client.get(f"/{entities}/{{item_id}}")
    assert response.status_code == 200
    assert response.json()["{entity}_id"] == item_id


def test_update_{entity}(client):
    create = client.post("/{entities}/", json={{"name": "Before Update"}})
    item_id = create.json()["{entity}_id"]

    response = client.put(
        f"/{entities}/{{item_id}}",
        json={{"name": "After Update"}},
    )
    assert response.status_code == 200
    assert response.json()["name"] == "After Update"


def test_delete_{entity}(client):
    create = client.post("/{entities}/", json={{"name": "To Delete"}})
    item_id = create.json()["{entity}_id"]

    response = client.delete(f"/{entities}/{{item_id}}")
    assert response.status_code == 200

    get_response = client.get(f"/{entities}/{{item_id}}")
    assert get_response.status_code == 404


def test_get_{entity}_not_found(client):
    response = client.get("/{entities}/nonexistent-id")
    assert response.status_code == 404
